  versus: '<polyline points="3 17 9 11 13 15 21 7"/><polyline opacity="0.45" points="3 7 9 13 13 9 21 17"/>',
  dollar: '<line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  film: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M10 9.5l5 2.5-5 2.5z"/>',
