---
import Base from '../layouts/Base.astro';
import GifSlot from '../components/GifSlot.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';

const faqs = [
  {
    q: 'How do I make an animated stock chart video?',
    a: 'Open Animate Stock on your iPhone, search for a ticker, pick a date range, and tap export. The app renders a smooth animated line chart of the price history and saves it as an MP4 video or GIF — no editing skills or desktop software needed.',
  },
  {
    q: 'Can I animate any time period?',
    a: 'Yes. You can animate anything from a few months to the entire trading history of a stock — for many companies that is 20+ years of data. The app shows the earliest available date for every ticker.',
  },
  {
    q: 'Can I mark events like earnings or crashes on the chart?',
    a: 'Yes. You can add event markers with a custom title, date, and color — for example “iPhone launch”, “COVID crash”, or “stock split”. Events you create are saved to a global library so you can reuse them across projects.',
  },
  {
    q: 'How long can the animation be?',
    a: 'You choose the duration: presets from 5 to 90 seconds, or set a custom length. Short loops work great as GIFs; longer renders suit YouTube and TikTok narration.',
  },
  {
    q: 'Is the exported video watermark-free?',
    a: 'Yes. Every MP4 and GIF exports clean, with your choice of background color, light or dark theme, line color, and chart title.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to create a stock price animation video',
  step: [
    { '@type': 'HowToStep', name: 'Search a ticker', text: 'Search for any stock, ETF, index, or crypto in the Animate Stock app.' },
    { '@type': 'HowToStep', name: 'Pick a date range', text: 'Choose any period from the available price history — months, years, or decades.' },
    { '@type': 'HowToStep', name: 'Customize and export', text: 'Set colors, theme, duration, and event markers, then export as MP4 video or animated GIF.' },
  ],
};
---

<Base
  title="Stock Price Animation Maker — Animated Stock Chart Videos | Animate Stock"
  description="Make animated stock chart videos on your iPhone. Animate any stock's price history over months, years, or decades and export as a watermark-free MP4 or GIF."
  path="/stock-price-animation"
>
  <div class="hero">
    <div class="container">
      <span class="eyebrow">Stock price animation</span>
      <h1>Animate any stock's <span class="accent">price history</span></h1>
      <p class="subtitle">
        Turn decades of price data into a cinematic animated chart. Pick a ticker,
        choose a time range, and export a video that tells the whole story.
      </p>
      <div class="cta-row">
        <a href="https://apps.apple.com/app/animate-stock/id0000000000" class="btn btn-primary">Download on the App Store</a>
      </div>
    </div>
  </div>

  <section>
    <div class="container">
      <!-- GIF SLOT: single-stock price animation — e.g. NVDA 2015→today, event markers on key dates -->
      <GifSlot
        label="Price animation demo GIF — single stock over a long range with event markers (e.g. NVDA 2015 → today)"
        caption="A stock price animation with event markers, created in Animate Stock."
      />
    </div>
  </section>

  <section class="center">
    <div class="container">
      <h2>How to make a stock price animation</h2>
      <div class="steps" style="margin-top: 36px; text-align: left;">
        <div class="step">
          <h3>Search the ticker</h3>
          <p>Type a company name or symbol. The app pulls full historical price data and shows you the available range.</p>
        </div>
        <div class="step">
          <h3>Set the scene</h3>
          <p>Choose your date range, animation duration, theme, colors, and add markers for the moments that matter.</p>
        </div>
        <div class="step">
          <h3>Export the video</h3>
          <p>Render a 30 fps MP4 or a looping GIF — landscape for video platforms, square for social feeds.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="center">
    <div class="container">
      <h2>Make the chart yours</h2>
      <p class="section-intro">Every detail of the animation is customizable.</p>
      <div class="grid grid-4" style="text-align: left;">
        <div class="card">
          <span class="card-icon">📅</span>
          <h3>Any date range</h3>
          <p>From last quarter's run to a 25-year retrospective.</p>
        </div>
        <div class="card">
          <span class="card-icon">📍</span>
          <h3>Event markers</h3>
          <p>Pin launches, earnings, splits, and crashes to exact dates.</p>
        </div>
        <div class="card">
          <span class="card-icon">⏱️</span>
          <h3>Your pace</h3>
          <p>5-second loops to 90-second deep dives, or any custom length.</p>
        </div>
        <div class="card">
          <span class="card-icon">🌗</span>
          <h3>Light or dark</h3>
          <p>Pick a theme and any background color to match your brand.</p>
        </div>
      </div>
    </div>
  </section>

  <Faq items={faqs} heading="Stock price animation FAQ" />

  <CtaBand
    heading="Animate your first chart today"
    text="Download Animate Stock for iPhone and turn any ticker's history into a video worth sharing."
  />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Base>
