---
import Base from '../layouts/Base.astro';
import GifSlot from '../components/GifSlot.astro';
import Faq from '../components/Faq.astro';
import CtaBand from '../components/CtaBand.astro';

const faqs = [
  {
    q: 'How do I make a stock chart GIF?',
    a: 'Open Animate Stock on your iPhone, pick a ticker and date range, choose GIF as the export format, and tap export. You get an infinitely looping animated chart GIF saved straight to your photo library — ready to post anywhere.',
  },
  {
    q: 'Where can I post stock chart GIFs?',
    a: 'GIFs auto-play almost everywhere: X (Twitter), Reddit, Discord, Slack, Telegram, and email newsletters. They’re the easiest way to make a chart move in places that don’t support video embeds.',
  },
  {
    q: 'What is the quality of the exported GIF?',
    a: 'GIFs render at 12 fps with the exact same animation as the MP4 export, optimized for smaller file sizes that load fast in feeds. For maximum quality, export the same project as a 30 fps MP4 instead.',
  },
  {
    q: 'Can I make a GIF comparing multiple stocks?',
    a: 'Yes — any project type exports as a GIF: single-stock price animations, market cap growth, multi-stock comparisons, and what-if scenarios.',
  },
  {
    q: 'Do the GIFs loop?',
    a: 'Yes, every exported GIF loops infinitely — ideal for mesmerizing chart loops that keep people watching.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to make a stock chart GIF',
  step: [
    { '@type': 'HowToStep', name: 'Pick a ticker and range', text: 'Search any stock, ETF, index, or crypto and choose the period to animate.' },
    { '@type': 'HowToStep', name: 'Choose GIF export', text: 'Select GIF as the output format and set the loop duration.' },
    { '@type': 'HowToStep', name: 'Export and post', text: 'Save the looping GIF to your photo library and post it anywhere GIFs auto-play.' },
  ],
};
---

<Base
  title="Stock Chart GIF Maker — Animated Chart GIFs for Social Media | Animate Stock"
  description="Make looping stock chart GIFs on your iPhone. Animate any ticker's price history and export an infinitely looping GIF for X, Reddit, Discord, and newsletters."
  path="/stock-chart-gif-maker"
>
  <div class="hero">
    <div class="container">
      <span class="eyebrow">GIF maker</span>
      <h1>Stock charts that <span class="accent">move</span>, everywhere GIFs play</h1>
      <p class="subtitle">
        Export any animated chart as an infinitely looping GIF. Auto-plays on X,
        Reddit, Discord, and in newsletters — no video player required.
      </p>
      <div class="cta-row">
        <a href="https://apps.apple.com/app/animate-stock/id0000000000" class="btn btn-primary">Download on the App Store</a>
      </div>
    </div>
  </div>

  <section>
    <div class="container">
      <!-- GIF SLOT: square looping GIF — short, punchy chart loop, square 1080x1080 -->
      <GifSlot
        ratio="square"
        label="GIF maker demo — a short looping square chart GIF (e.g. a 5-second BTC loop)"
        caption="A square 1080x1080 looping GIF, straight out of Animate Stock."
      />
    </div>
  </section>

  <section class="center">
    <div class="container">
      <h2>GIF vs MP4 — pick the right format</h2>
      <p class="section-intro">Both export from the same project. Use the one your platform loves.</p>
      <div style="max-width: 760px; margin: 0 auto; overflow-x: auto;">
        <table class="spec-table">
          <thead>
            <tr>
              <th></th>
              <th>Animated GIF</th>
              <th>MP4 video</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Best for</td>
              <td>X, Reddit, Discord, newsletters</td>
              <td>YouTube, TikTok, Instagram</td>
            </tr>
            <tr>
              <td>Playback</td>
              <td>Auto-plays, loops forever</td>
              <td>Tap to play, full quality</td>
            </tr>
            <tr>
              <td>Frame rate</td>
              <td>12 fps, lightweight</td>
              <td>30 fps, 9 Mbps H.264</td>
            </tr>
            <tr>
              <td>Aspect ratios</td>
              <td>Landscape or square</td>
              <td>Landscape (1440×1080) or square (1080×1080)</td>
            </tr>
            <tr>
              <td>Watermark</td>
              <td>None</td>
              <td>None</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="center">
    <div class="container">
      <h2>Three taps to a looping chart</h2>
      <div class="steps" style="margin-top: 36px; text-align: left;">
        <div class="step">
          <h3>Pick a ticker &amp; range</h3>
          <p>Any stock, ETF, index, or crypto with historical data.</p>
        </div>
        <div class="step">
          <h3>Choose GIF export</h3>
          <p>Set the loop length — short 5-second loops are the most hypnotic.</p>
        </div>
        <div class="step">
          <h3>Post it</h3>
          <p>Saved straight to your photo library, ready for any feed or chat.</p>
        </div>
      </div>
    </div>
  </section>

  <Faq items={faqs} heading="Stock chart GIF FAQ" />

  <CtaBand
    heading="Make your first chart GIF"
    text="Download Animate Stock and export a looping chart GIF in under a minute."
  />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Base>
